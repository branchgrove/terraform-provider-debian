FROM debian:bookworm

RUN apt-get update && \
    apt-get install -y --no-install-recommends openssh-server && \
    rm -rf /var/lib/apt/lists/* && \
    mkdir -p /run/sshd /root/.ssh && \
    chmod 700 /root/.ssh && \
    echo 'PermitRootLogin yes' > /etc/ssh/sshd_config.d/10-root.conf

EXPOSE 22
CMD ["/usr/sbin/sshd", "-D"]
